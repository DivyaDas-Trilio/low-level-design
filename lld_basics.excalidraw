    {
      "id": "T-PpDpX41XyMfg2pYLlti",
      "type": "text",
      "x": 465.44921875,
      "y": 1362.81640625,
      "width": 1078.17919921875,
      "height": 250,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
