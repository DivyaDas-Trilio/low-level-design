      "seed": 2076577589,
      "version": 905,
      "versionNonce": 797578613,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776660577370,
      "link": null,
      "locked": false,
      "text": ". Above are components that are essential to write clean and maintained code.\n. But when we receive to design LLD Problem Statement only knowledge of above components will not work.\n  we need a way to combine some/all in a hood. Basically, we need a structured and disciplined way that guide \n  design of system into code which will. solve problems.\n. So, what are existing disciplined approaches that solves system into code:-\n    ->  Domain Driven Design(Its way to think about problem)\n    ->  Layered Architecture(How system is structured before coding.)\n    ->  Microservices Architecture(How system is structured before coding.)\n    ->  Event Driven Architecture(How system is structured before coding.)\n    ->  Clean Architecture(How system is structured before coding.) ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": ". Above are components that are essential to write clean and maintained code.\n. But when we receive to design LLD Problem Statement only knowledge of above components will not work.\n  we need a way to combine some/all in a hood. Basically, we need a structured and disciplined way that guide \n  design of system into code which will. solve problems.\n. So, what are existing disciplined approaches that solves system into code:-\n    ->  Domain Driven Design(Its way to think about problem)\n    ->  Layered Architecture(How system is structured before coding.)\n    ->  Microservices Architecture(How system is structured before coding.)\n    ->  Event Driven Architecture(How system is structured before coding.)\n    ->  Clean Architecture(How system is structured before coding.) ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "ChG-cQUWHF4bNgTS1CWFx",
      "type": "text",
      "x": 463.47265625,
      "y": 2063.45703125,
      "width": 668.6594848632812,
      "height": 475,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
