      "link": null,
      "locked": false,
      "text": " 1. User Flow Diagrams:-\n    -> User\n         ↓\n        Select City\n         ↓\n        Search movie\n         ↓\n        Select show\n         ↓\n        Select seats\n         ↓\n        Lock seats\n         ↓\n        Create booking\n         ↓\n        Make payment\n         ↓\n        Confirm booking",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": " 1. User Flow Diagrams:-\n    -> User\n         ↓\n        Select City\n         ↓\n        Search movie\n         ↓\n        Select show\n         ↓\n        Select seats\n         ↓\n        Lock seats\n         ↓\n        Create booking\n         ↓\n        Make payment\n         ↓\n        Confirm booking",
      "autoResize": true,
